@model List<ExclusiveMVC.Models.Cart>

<h2>💳 Checkout</h2>

<div class="row">

    <!-- LEFT SIDE -->
    <div class="col-md-6">

        <h4>Billing Details</h4>

        <form method="post" action="/Order/PlaceOrder">

            <!-- ✅ BILLING -->
            <input name="name" class="form-control mb-2" placeholder="Full Name" required />
            <input name="address" class="form-control mb-2" placeholder="Address" required />
            <input name="state" class="form-control mb-2" placeholder="State" required />
            <input name="city" class="form-control mb-2" placeholder="City" required />
            <input name="pincode" class="form-control mb-2" placeholder="Pin Code" required />
            <input name="phone" class="form-control mb-2" placeholder="Phone" required />

            <!-- 💳 PAYMENT -->
            <h5 class="mt-3">Payment Method</h5>

            <div class="mb-3">
                <input type="radio" name="paymentMethod" value="Card" checked onclick="showPayment('card')"> Card  
                <input type="radio" name="paymentMethod" value="UPI" onclick="showPayment('upi')"> UPI  
                <input type="radio" name="paymentMethod" value="NetBanking" onclick="showPayment('net')"> Net Banking  
            </div>

            <!-- CARD -->
            <div id="cardSection">
                <input name="cardNumber" class="form-control mb-2" placeholder="Card Number" />
                <input name="expiry" class="form-control mb-2" placeholder="Expiry (MM/YY)" />
                <input name="cvv" class="form-control mb-2" placeholder="CVV" />
            </div>

            <!-- UPI -->
            <div id="upiSection" style="display:none;">
                <input name="upiId" class="form-control mb-2" placeholder="Enter UPI ID (example@upi)" />
            </div>

            <!-- NET BANKING -->
            <div id="netSection" style="display:none;">
                <select name="bank" class="form-control mb-2">
                    <option value="">Select Bank</option>
                    <option>SBI</option>
                    <option>HDFC</option>
                    <option>ICICI</option>
                    <option>IDBI</option>
                    <option>Kotak</option>
                </select>
            </div>

            <button type="submit" class="btn btn-success w-100 mt-3">
                Place Order
            </button>

        </form>

    </div>

    <!-- RIGHT SIDE -->
    <div class="col-md-6">

        <h4>Your Order</h4>

        @foreach (var item in Model)
        {
            <p>@item.Name - ₹ @item.Price x @item.Quantity</p>
        }

        <hr />

        <h3>Total: ₹ @Model.Sum(x => x.Price * x.Quantity)</h3>

    </div>

</div>

<!-- 🔥 SCRIPT -->
<script>
function showPayment(type) {
    document.getElementById("cardSection").style.display = "none";
    document.getElementById("upiSection").style.display = "none";
    document.getElementById("netSection").style.display = "none";

    if (type === "card") {
        document.getElementById("cardSection").style.display = "block";
    }
    else if (type === "upi") {
        document.getElementById("upiSection").style.display = "block";
    }
    else if (type === "net") {
        document.getElementById("netSection").style.display = "block";
    }
}
</script>
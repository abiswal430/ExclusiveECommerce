@model List<ExclusiveMVC.Models.Cart>

<h2>🛒 Your Cart</h2>

<table class="table">
    <tr>
        <th>Product</th>
        <th>Price</th>
        <th>Qty</th>
        <th>Total</th>
        <th>Action</th>
    </tr>

@foreach (var item in Model)
{
    <tr>
        <td>@item.Name</td>
        <td>₹ @item.Price</td>
        <td>@item.Quantity</td>
        <td>₹ @(item.Price * item.Quantity)</td>
        <td>
            <a href="/Cart/Remove?name=@item.Name" class="btn btn-danger btn-sm">Remove</a>
        </td>
    </tr>
}

</table>

<h3>Total: ₹ @Model.Sum(x => x.Price * x.Quantity)</h3>

<a href="/Cart/Checkout" class="btn btn-danger">Proceed to Checkout</a>
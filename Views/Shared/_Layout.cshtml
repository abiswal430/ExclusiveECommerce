<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Exclusive</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Font Awesome (🔥 Third Party Library) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

    <!-- 🔥 NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm px-4">

        <!-- LOGO -->
        <a class="navbar-brand fw-bold fs-3" href="/">Exclusive</a>

        <!-- TOGGLE -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- MENU -->
        <div class="collapse navbar-collapse" id="navbarNav">

            <!-- LEFT MENU -->
            <ul class="navbar-nav me-auto">

                <li class="nav-item mx-2">
                    <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Home</a>
                </li>

                <li class="nav-item mx-2">
                    <a class="nav-link text-dark" asp-controller="Home" asp-action="About">About</a>
                </li>

                <li class="nav-item mx-2">
                    <a class="nav-link text-dark" asp-controller="Home" asp-action="Contact">Contact</a>
                </li>

                <!-- ✅ API PRODUCTS -->
                <li class="nav-item mx-2">
                    <a class="nav-link text-dark" href="/Api/Products">
                        <i class="fas fa-globe"></i> API Products
                    </a>
                </li>

            </ul>

            <!-- RIGHT SIDE -->
            <ul class="navbar-nav align-items-center ms-auto">

                <!-- ADMIN -->
                <li class="nav-item me-3">
                    <a class="nav-link text-dark fw-semibold" href="/Admin">
                        <i class="fas fa-cog"></i> Admin
                    </a>
                </li>

                <!-- 🛒 CART WITH COUNT -->
                <li class="nav-item me-3">
                    <a class="nav-link position-relative" href="/Cart">
                        <i class="fas fa-shopping-cart"></i> Cart

                        <!-- 🔴 BADGE -->
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                            @(Context.Session.GetInt32("CartCount") ?? 0)
                        </span>
                    </a>
                </li>

                @if (Context.Session.GetString("username") != null)
                {
                    <!-- USERNAME -->
                    <li class="nav-item me-2">
                        <span class="nav-link text-primary fw-bold">
                            <i class="fas fa-user"></i> @Context.Session.GetString("username")
                        </span>
                    </li>

                    <!-- LOGOUT -->
                    <li class="nav-item">
                        <a class="nav-link text-danger fw-semibold" href="/Account/Logout">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </a>
                    </li>
                }
                else
                {
                    <!-- LOGIN -->
                    <li class="nav-item me-2">
                        <a class="btn btn-primary px-4 py-2 rounded-pill shadow-sm me-2 text-white"
                            href="/Account/Login">
                            <i class="fas fa-sign-in-alt"></i> Login
                        </a>
                    </li>

                    <!-- REGISTER -->
                    <li class="nav-item">
                        <a class="btn btn-primary px-4 py-2 rounded-pill shadow-sm text-white"
                            href="/Account/Register">
                            <i class="fas fa-user-plus"></i> Register
                        </a>
                       
                    </li>
                }

            </ul>

        </div>
    </nav>

    <!-- 🔥 BODY -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- 🔥 FOOTER -->
    <footer class="text-center mt-5 border-top pt-3 text-muted">
        © 2026 - Exclusive | Built with ❤️
    </footer>

    <!-- jQuery -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <!-- Bootstrap -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- 🔥 SweetAlert (Third Party Library) -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- ✅ SUCCESS POPUP -->
    @if (TempData["success"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Success',
                text: '@TempData["success"]',
                confirmButtonColor: '#3085d6'
            });
        </script>
    }

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Exclusive</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

    <!-- 🔥 NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm px-4">

        <!-- LOGO -->
        <a class="navbar-brand fw-bold fs-3" href="/">Exclusive</a>

        <!-- TOGGLE -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- MENU -->
        <div class="collapse navbar-collapse" id="navbarNav">

            <!-- LEFT MENU -->
            <ul class="navbar-nav me-auto">
                <li class="nav-item mx-2">
                    <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Home</a>
                </li>

                <li class="nav-item mx-2">
                    <a class="nav-link text-dark" asp-controller="Home" asp-action="About">About</a>
                </li>

                <li class="nav-item mx-2">
                    <a class="nav-link text-dark" asp-controller="Home" asp-action="Contact">Contact</a>
                </li>
            </ul>

            <!-- RIGHT SIDE -->
            <ul class="navbar-nav align-items-center ms-auto">

    <!-- ADMIN -->
    <li class="nav-item me-3">
        <a class="nav-link text-dark fw-semibold" href="/Admin">
            ⚙️ Admin
        </a>
    </li>

    <!-- CART -->
    <li class="nav-item me-3">
        <a class="nav-link" href="/Cart">
            🛒 Cart
        </a>
    </li>

    @if (Context.Session.GetString("username") != null)
    {
        <!-- USERNAME -->
        <li class="nav-item me-2">
            <span class="nav-link text-primary fw-bold">
                @Context.Session.GetString("username")
            </span>
        </li>

        <!-- LOGOUT -->
        <li class="nav-item">
            <a class="nav-link text-danger" href="/Account/Logout">Logout</a>
        </li>
    }
    else
    {
        <!-- LOGIN -->
        <li class="nav-item me-2">
            <a class="nav-link btn btn-outline-dark px-3" href="/Account/Login">
                Login
            </a>
        </li>

        <!-- REGISTER -->
        <li class="nav-item">
            <a class="nav-link btn btn-dark text-white px-3" href="/Account/Register">
                Register
            </a>
        </li>
    }

</ul>

            </ul>

        </div>
    </nav>

    <!-- 🔥 BODY -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- 🔥 FOOTER -->
    <footer class="text-center mt-5 border-top pt-3 text-muted">
        © 2026 - Exclusive | Built with ❤️
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
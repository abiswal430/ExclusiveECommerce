@model List<ExclusiveMVC.Models.Order>

<h2 class="mb-4">📦 My Orders</h2>

<table class="table table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Phone</th>
            <th>Address</th>
            <th>Total</th>
            <th>Date</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var o in Model)
        {
            <tr>
                <td>@o.CustomerName</td>
                <td>@o.Phone</td>
                <td>@o.Address</td>
                <td>₹ @o.TotalAmount</td>
                <td>@o.OrderDate.ToString("dd-MM-yyyy HH:mm")</td>

                <!-- ✅ STATUS -->
                <td>
                    @if (o.Status == "Placed")
                    {
                        <span class="badge bg-primary">Placed</span>
                    }
                    else if (o.Status == "Delivered")
                    {
                        <span class="badge bg-success">Delivered</span>
                    }
                    else if (o.Status == "Cancelled")
                    {
                        <span class="badge bg-danger">Cancelled</span>
                    }
                </td>

                <!-- ✅ ACTION BUTTONS -->
                <td>
                    @if (o.Status == "Placed")
                    {
                        <!-- Cancel -->
                        <a href="/Order/Cancel/@o.Id" class="btn btn-sm btn-danger">
                            Cancel
                        </a>

                        <!-- Admin: Mark Delivered -->
                        <a href="/Order/MarkDelivered/@o.Id" class="btn btn-sm btn-success ms-2">
                            Delivered
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">No Action</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>